[Unit]
Description=Alpha Research API
After=network.target

[Service]
Type=simple
WorkingDirectory=/srv/alpha-research/repo
Environment=PORT=8787
Environment=DATASET_INSTANCE_ROOT=/srv/alpha-research/data/instances
ExecStart=/usr/bin/npm run dev:api
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target

