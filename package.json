{
  "name": "alpha-research",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && npm run test:cli",
    "test:cli": "RESEARCH_SESSION_DIR=.tmp/research-test RESEARCH_DISABLE_RUN_WATCHER=1 tsx --test apps/cli/test/*.test.ts",
    "test:golden": "RESEARCH_SESSION_DIR=.tmp/research-test RESEARCH_DISABLE_RUN_WATCHER=1 tsx --test apps/cli/test/golden.test.ts",
    "harness:check": "RESEARCH_SESSION_DIR=.tmp/research-harness RESEARCH_DISABLE_RUN_WATCHER=1 tsx scripts/harness-check.ts",
    "dev": "npm run dev -w @alpha-datasets/frontend",
    "dev:api": "npm run dev -w @alpha-datasets/api",
    "dev:frontend": "npm run dev -w @alpha-datasets/frontend",
    "dev:ingest": "npm run dev -w @alpha-datasets/ingest",
    "dev:cli": "npm run dev -w @alpha-datasets/cli",
    "cli": "node apps/cli/dist/index.js",
    "dev:stack": "concurrently -k -n api,frontend \"npm run dev:api\" \"npm run dev:frontend\"",
    "ingest:tabular": "python3 scripts/normalize_tabular_dataset.py",
    "ingest:unstructured": "python3 scripts/normalize_unstructured_dataset.py"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.3"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "hono": "^4.11.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
