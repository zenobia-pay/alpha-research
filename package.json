{
  "name": "alpha-research",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && npm run test:cli && npm run test:canonical",
    "test:cli": "RESEARCH_SESSION_DIR=.tmp/research-test RESEARCH_DISABLE_RUN_WATCHER=1 tsx --test --test-force-exit apps/cli/test/*.test.ts",
    "test:canonical": "tsx --test scripts/canonical-dataset.test.ts",
    "test:golden": "RESEARCH_SESSION_DIR=.tmp/research-test RESEARCH_DISABLE_RUN_WATCHER=1 tsx --test apps/cli/test/golden.test.ts",
    "symphony:test": "RESEARCH_SESSION_DIR=.tmp/research-symphony-test RESEARCH_DISABLE_RUN_WATCHER=1 tsx --test apps/cli/test/symphony-cases.test.ts",
    "harness:check": "RESEARCH_SESSION_DIR=.tmp/research-harness RESEARCH_DISABLE_RUN_WATCHER=1 tsx scripts/harness-check.ts",
    "docs:check": "tsx scripts/docs-check.ts",
    "docs:mintlify:dev": "cd docs && npx mint@latest dev",
    "docs:product-tests:site": "tsx scripts/build-product-test-site.ts",
    "architecture:check": "tsx scripts/architecture-check.ts",
    "smoke:local": "tsx scripts/smoke-local.ts",
    "product:e2e:econ": "tsx scripts/product-e2e-econ.ts",
    "product:e2e:econ:discover": "RESEARCH_PRODUCT_E2E_ECON_MODE=discover tsx scripts/product-e2e-econ.ts",
    "product:e2e:econ:environment": "RESEARCH_PRODUCT_E2E_ECON_MODE=environment tsx scripts/product-e2e-econ.ts",
    "product:e2e:econ:hypothesis": "RESEARCH_PRODUCT_E2E_ECON_MODE=hypothesis tsx scripts/product-e2e-econ.ts",
    "product:e2e:econ:normalization-plan": "RESEARCH_PRODUCT_E2E_ECON_MODE=normalization-plan tsx scripts/product-e2e-econ.ts",
    "product:e2e:econ:normalization-execution": "RESEARCH_PRODUCT_E2E_ECON_MODE=normalization-execution tsx scripts/product-e2e-econ.ts",
    "product:e2e:tweets": "tsx scripts/product-e2e-tweets.ts",
    "test:slow": "npm run test:slow:econ && npm run test:slow:tweets",
    "test:slow:econ": "npm run test:slow:econ:discover && npm run test:slow:econ:normalization-plan && npm run test:slow:econ:normalization-execution && npm run test:slow:econ:environment && npm run test:slow:econ:hypothesis",
    "test:slow:econ:discover": "RESEARCH_PRODUCT_E2E_LIVE=1 RESEARCH_PRODUCT_E2E_ECON_MODE=discover tsx scripts/product-e2e-econ.ts",
    "test:slow:econ:environment": "RESEARCH_PRODUCT_E2E_LIVE=1 RESEARCH_PRODUCT_E2E_ECON_MODE=environment tsx scripts/product-e2e-econ.ts",
    "test:slow:econ:hypothesis": "RESEARCH_PRODUCT_E2E_LIVE=1 RESEARCH_PRODUCT_E2E_ECON_MODE=hypothesis tsx scripts/product-e2e-econ.ts",
    "test:slow:econ:normalization-plan": "RESEARCH_PRODUCT_E2E_LIVE=1 RESEARCH_PRODUCT_E2E_ECON_MODE=normalization-plan tsx scripts/product-e2e-econ.ts",
    "test:slow:econ:normalization-execution": "RESEARCH_PRODUCT_E2E_LIVE=1 RESEARCH_PRODUCT_E2E_ECON_MODE=normalization-execution tsx scripts/product-e2e-econ.ts",
    "test:slow:tweets": "RESEARCH_PRODUCT_E2E_LIVE=1 tsx scripts/product-e2e-tweets.ts",
    "deploy:check": "tsx scripts/deploy-check.ts",
    "canonical:refresh": "node scripts/start-canonical-public-dataset-refresh-jobs.mjs",
    "canonical:refresh:status": "node scripts/start-canonical-public-dataset-refresh-jobs.mjs --status-only",
    "canonical:refresh:dry-run": "node scripts/start-canonical-public-dataset-refresh-jobs.mjs --dry-run",
    "canonical:dataset": "tsx scripts/canonical-dataset.ts",
    "canonical:expand": "node scripts/start-canonical-dataset-expansion-jobs.mjs",
    "canonical:expand:dry-run": "node scripts/start-canonical-dataset-expansion-jobs.mjs --dry-run",
    "canonical:improve": "node scripts/start-canonical-dataset-improvement-jobs.mjs",
    "canonical:improve:dry-run": "node scripts/start-canonical-dataset-improvement-jobs.mjs --dry-run",
    "agent:check": "npm run build && npm run typecheck && npm run test && npm run harness:check && npm run docs:check && npm run architecture:check && npm run smoke:local && npm run deploy:check",
    "symphony:doctor": "tsx scripts/symphony.ts doctor",
    "symphony:bootstrap": "tsx scripts/symphony.ts bootstrap",
    "symphony:seed": "tsx scripts/symphony.ts seed",
    "symphony:start": "tsx scripts/symphony.ts start",
    "dev": "npm run dev -w @rprend/alpha-frontend",
    "dev:api": "npm run dev -w @rprend/alpha-api",
    "dev:frontend": "npm run dev -w @rprend/alpha-frontend",
    "dev:ingest": "npm run dev -w @rprend/alpha-ingest",
    "dev:cli": "npm run dev -w @rprend/research",
    "cli": "node apps/cli/dist/index.js",
    "dev:stack": "concurrently -k -n api,frontend \"npm run dev:api\" \"npm run dev:frontend\"",
    "ingest:tabular": "python3 scripts/normalize_tabular_dataset.py",
    "ingest:unstructured": "python3 scripts/normalize_unstructured_dataset.py"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.3"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "hono": "^4.11.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
